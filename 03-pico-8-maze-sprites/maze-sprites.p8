--sprites took from:
--https://opengameart.org/content/dungeon-crawl-32x32-tiles

function _init()
	init_map()
	init_player()
	init_atlas()
	init_dungeon()
	
	-- 64x64 pixels mode
	poke(0x5f2c,3)
	
end

function _update()
	update_player()
	update_map()
end

function _draw()
	cls(0)
	draw_dungeon()
	draw_map()
end
