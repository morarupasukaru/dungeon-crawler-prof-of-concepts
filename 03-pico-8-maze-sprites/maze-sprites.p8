-- utils
function print_center(t,y)
	x = (64-#t*4)/2
	if x < 0 then
		x = 0
	end
	rectfill(x-1, y-1, x+#t*4+3, y+5,6)
	print(t, x, y, 0)
end

pulse={}
function pulse:new(incr)
  local res = {}
  res.incr=incr
  res.val=0
		return setmetatable(res, {__index = self} )
end

function pulse:update()
	self.val+=self.incr
end

function pulse:bool()
  return flr(self.val)%2==1
end
